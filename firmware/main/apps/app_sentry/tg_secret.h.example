#pragma once
// Copy this file to `tg_secret.h` (which is git-ignored) and fill in your values.
// If tg_secret.h is absent, the Telegram push is compiled out (sentry still works).
//   TG_BOT_TOKEN: from @BotFather  (e.g. "123456789:AA...")
//   TG_CHAT_ID:   your chat id, from @userinfobot  (e.g. "123456789")
#define TG_BOT_TOKEN "PASTE_BOTFATHER_TOKEN_HERE"
#define TG_CHAT_ID   "PASTE_CHAT_ID_HERE"
